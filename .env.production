# =============================================================================
# WebCrawler Pro - Production Environment (.env.production)
# Domain: orgitron.com | SSL via Let's Encrypt (Traefik)
# =============================================================================

# =============================================================================
# Domain & SSL (Traefik / Let's Encrypt)
# =============================================================================
DOMAIN=orgitron.com
ACME_EMAIL=eddi@validosta.de

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_DB=webcrawler
POSTGRES_USER=webcrawler
POSTGRES_PASSWORD=9335fGOdtK62nC56EgOJ02CYmXO4SrSG
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://webcrawler:9335fGOdtK62nC56EgOJ02CYmXO4SrSG@postgres:5432/webcrawler

# =============================================================================
# Cache & Message Broker (Redis)
# =============================================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =============================================================================
# Application URLs
# =============================================================================
FRONTEND_URL=https://orgitron.com
APP_URL=https://orgitron.com
CORS_ORIGINS=https://orgitron.com,https://www.orgitron.com
ALLOWED_HOSTS=orgitron.com,www.orgitron.com,backend
NEXT_PUBLIC_API_URL=/api
INTERNAL_API_URL=http://backend:8000

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=a402228c851acbc78128e527542261f0d404c8cf9b70f5b29c011c87cec2d059
DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# Storage (MinIO / S3)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=sivPahQqGMDzB5Y5jOnqWLy2Zkeyt8ne
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=webcrawler
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=sivPahQqGMDzB5Y5jOnqWLy2Zkeyt8ne
AWS_S3_BUCKET=webcrawler

# =============================================================================
# Traefik Dashboard Auth
# Generate: htpasswd -nb admin yourpassword | sed -e 's/\$/\$\$/g'
# =============================================================================
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$changeme$$placeholder

# =============================================================================
# Google OAuth2 (Search Console)
# =============================================================================
GOOGLE_REDIRECT_URI=https://orgitron.com/api/integrations/gsc/callback

# =============================================================================
# Watchtower Auto-Update
# =============================================================================
WATCHTOWER_POLL_INTERVAL=86400
SLACK_WEBHOOK_URL=

# =============================================================================
# Email Alerting (optional)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=eddi@validosta.de
SMTP_PASSWORD=
SMTP_FROM=webcrawler@orgitron.com

# =============================================================================
# AI Researcher
# =============================================================================
RESEARCHER_MODEL=google/gemini-1.5-flash-8b
